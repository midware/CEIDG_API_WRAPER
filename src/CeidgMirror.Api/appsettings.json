{
  "CeidgApi": {
    "BaseUrl": "https://dane.biznes.gov.pl/api/ceidg/v3/",
    "ReportsBaseUrl": "https://dane.biznes.gov.pl/raporty/",
    "JwtToken": null,
    "RequestLimit": 50,
    "WindowSeconds": 180,
    "HourlyRequestLimit": 1000,
    "HourlyWindowSeconds": 3600,
    "MinimumRequestIntervalSeconds": 4.0,
    "RequestTimeoutSeconds": 300
  },
  "Postgres": {
    "ConnectionString": "Host=localhost;Port=5433;Database=ceidg_mirror;Username=postgres;Password=postgres"
  },
  "ProductApi": {
    "FreeRegistrationTokens": 1000,
    "DefaultPageSize": 25,
    "MaxPageSize": 100
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
